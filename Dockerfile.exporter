FROM debian:stable-slim@sha256:ee12ffb55625b99d62837a72f037d9b2f18fd0c787a89c2b9a4f09666c48776c AS builder

EXPOSE 9978

# Install build dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       git \
       golang-go \
       ca-certificates

# Clone and build gpsd-exporter
RUN git clone https://github.com/natesales/gpsd-exporter.git /src \
    && cd /src \
    && go build -o gpsd-exporter .

FROM debian:stable-slim@sha256:ee12ffb55625b99d62837a72f037d9b2f18fd0c787a89c2b9a4f09666c48776c

# Copy the built binary
COPY --from=builder /src/gpsd-exporter /usr/bin/gpsd-exporter

ENTRYPOINT ["/usr/bin/gpsd-exporter", "-d", "gpsd:2947"]


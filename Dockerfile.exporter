FROM debian:stable-slim@sha256:8f0c555de6a2f9c2bda1b170b67479d11f7f5e3b66bb4a7a1d8843361c9dd3ff AS builder

EXPOSE 9978

# Install build dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       git \
       golang-go \
       ca-certificates

# Clone and build gpsd-exporter
RUN git clone https://github.com/natesales/gpsd-exporter.git /src \
    && cd /src \
    && go build -o gpsd-exporter .

FROM debian:stable-slim@sha256:8f0c555de6a2f9c2bda1b170b67479d11f7f5e3b66bb4a7a1d8843361c9dd3ff

# Copy the built binary
COPY --from=builder /src/gpsd-exporter /usr/bin/gpsd-exporter

ENTRYPOINT ["/usr/bin/gpsd-exporter", "-d", "gpsd:2947"]

